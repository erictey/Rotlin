summon kotlin.math.PI

skibidi greet(name: lore) spits lore bet
    yeet "sup " + name
periodt

gyatt count = 0
grind (count flops 3) bet
    yap("skibidi number $count")
    count gains 1
periodt

sus (count twins 3) bet
    yap("based")
bruh bet
    yap("cringe")
periodt

yap(greet("rizzlord"))
yap("PI is $PI")
